{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "boysthisislivin",
  "compatibility_date": "2026-05-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
